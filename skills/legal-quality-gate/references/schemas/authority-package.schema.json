{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "legal-os://schemas/authority-package.schema.json",
  "title": "Legal OS Authority Package",
  "type": "object",
  "required": ["schema_version", "matter_task_id", "verified_at", "verified_by", "propositions"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "matter_task_id": {"type": "string", "minLength": 3},
    "verified_at": {"type": "string", "minLength": 10},
    "verified_by": {"type": "string", "minLength": 1},
    "propositions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["proposition_id", "text", "authority_id", "source_type", "title", "issuing_body", "locator", "pinpoint", "current_status", "accessed_at", "support", "scope", "contrary_sources", "review_status"],
        "properties": {
          "proposition_id": {"type": "string", "minLength": 2},
          "text": {"type": "string", "minLength": 2},
          "authority_id": {"type": "string", "minLength": 2},
          "source_type": {"enum": ["law", "administrative-regulation", "judicial-interpretation", "department-rule", "local-rule", "case", "policy", "official-publication"]},
          "title": {"type": "string", "minLength": 2},
          "issuing_body": {"type": "string", "minLength": 2},
          "locator": {"type": "string", "minLength": 4},
          "pinpoint": {"type": "string", "minLength": 1},
          "current_status": {"enum": ["effective", "verified-source", "historical", "repealed", "superseded", "unverified"]},
          "accessed_at": {"type": "string", "minLength": 10},
          "support": {"type": "string", "minLength": 2},
          "scope": {"type": "string", "minLength": 2},
          "contrary_sources": {"type": "array"},
          "review_status": {"enum": ["approved", "rejected", "pending"]}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
